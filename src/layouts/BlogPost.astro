---
import BaseLayout from './BaseLayout.astro';
import { getLangFromUrl, useTranslations, defaultLang, type Lang } from '@/i18n/index';

interface Props {
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  heroImage?: string;
  lang?: Lang;
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
}

const { title, description, pubDate, tags = [], heroImage, prevPost, nextPost, lang: propLang } = Astro.props;
const lang = propLang ?? getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const base = lang === defaultLang ? '' : `/${lang}`;

const plainTitle = title.replace(/<[^>]+>/g, '');
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={plainTitle} description={description} image={heroImage}>
  <article>
    {heroImage && (
      <div class="w-full rounded-xl overflow-hidden mb-8">
        <img src={heroImage} alt={plainTitle} class="w-full h-auto" />
      </div>
    )}
    <header class="mb-10">
      <div class="flex flex-wrap items-center gap-2 text-sm text-zinc-500 mb-3">
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        {tags.length > 0 && (
          <>
            <span>·</span>
            <div class="flex flex-wrap gap-2">
              {tags.map(tag => (
                <a href={`${base}/tags/${tag}`} class="text-amber-500 dark:text-amber-400 hover:underline">#{tag}</a>
              ))}
            </div>
          </>
        )}
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-zinc-900 dark:text-zinc-100 leading-tight" set:html={title} />
      {description && <p class="mt-3 text-zinc-500 dark:text-zinc-400 text-base sm:text-lg">{description}</p>}
    </header>

    <div class="prose prose-zinc dark:prose-invert max-w-none
      prose-headings:font-semibold
      prose-a:text-amber-500 dark:prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline
      prose-code:text-amber-600 dark:prose-code:text-amber-300 prose-code:font-mono
      prose-pre:bg-zinc-100 dark:prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-200 dark:prose-pre:border-zinc-800">
      <slot />
    </div>
  </article>

  <div class="mt-16 pt-8 border-t border-zinc-200 dark:border-zinc-800">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        {prevPost ? (
          <a href={prevPost.slug} class="group block">
            <span class="text-xs text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">{t('post.older')}</span>
            <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-amber-500 dark:group-hover:text-amber-400 transition-colors mt-1 line-clamp-2" set:html={prevPost.title} />
          </a>
        ) : (
          <a href={`${base}/blog`} class="text-amber-500 dark:text-amber-400 hover:underline text-sm">{t('post.back')}</a>
        )}
      </div>
      <div class="flex-1 text-right">
        {nextPost && (
          <a href={nextPost.slug} class="group block">
            <span class="text-xs text-zinc-400 dark:text-zinc-600 uppercase tracking-widest">{t('post.newer')}</span>
            <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-amber-500 dark:group-hover:text-amber-400 transition-colors mt-1 line-clamp-2" set:html={nextPost.title} />
          </a>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
