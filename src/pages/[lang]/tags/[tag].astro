---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, type Lang } from '@/i18n/index';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const langs = ['ru', 'uk', 'de'] as Lang[];
  const paths = [];
  for (const lang of langs) {
    const posts = all.filter(p => p.slug.startsWith(`${lang}/`));
    const tags = [...new Set(posts.flatMap(p => p.data.tags))];
    for (const tag of tags) {
      paths.push({ params: { lang, tag }, props: { lang, tag } });
    }
  }
  return paths;
}

const { lang, tag } = Astro.props as { lang: Lang; tag: string };
const t = useTranslations(lang);
const base = `/${lang}`;

const posts = (await getCollection('blog'))
  .filter(p => p.slug.startsWith(`${lang}/`) && !p.data.draft && p.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`#${tag}`}>
  <div class="mb-8 flex items-center gap-3">
    <a href={`${base}/blog`} class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-600 dark:hover:text-zinc-300 text-sm transition-colors">{t('tag.back')}</a>
    <span class="text-zinc-300 dark:text-zinc-700">/</span>
    <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">{tag}</span>
    <span class="text-zinc-400 dark:text-zinc-500 text-sm">{posts.length}</span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {posts.map(post => (
      <BlogCard post={post} href={`${base}/blog/${post.slug.replace(`${lang}/`, '')}`} tagBase={`${base}/tags/`} />
    ))}
  </div>
</BaseLayout>
