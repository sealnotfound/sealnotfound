---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { readingTime } from '@/utils/readingTime';
import { useTranslations, type Lang } from '@/i18n/index';

export async function getStaticPaths() {
  return (['ru', 'uk', 'de'] as Lang[]).map(lang => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const base = `/${lang}`;

const posts = (await getCollection('blog'))
  .filter(p => p.slug.startsWith(`${lang}/`) && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map(p => ({
    slug: p.slug.replace(`${lang}/`, ''),
    title: p.data.title,
    description: p.data.description ?? '',
    tags: p.data.tags,
    heroImage: p.data.heroImage ?? '',
    date: p.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }),
    readTime: readingTime(p.body),
    base,
  }));

const totalStr = t('search.total', { n: posts.length });
const filteredStr = t('search.filtered', { n: 0, total: posts.length });
---

<BaseLayout title={t('search.title')}>
  <h1 class="text-2xl font-bold mb-6 text-zinc-900 dark:text-zinc-100">{t('search.title')}</h1>

  <div class="relative mb-8">
    <input id="search-input" type="text" placeholder={t('search.placeholder')} autocomplete="off"
      class="w-full px-4 py-3 pl-10 rounded-xl border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100 placeholder-zinc-400 dark:placeholder-zinc-600 focus:outline-none focus:border-amber-400 dark:focus:border-amber-500 transition-colors" />
    <svg class="absolute left-3 top-3.5 w-4 h-4 text-zinc-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z"/>
    </svg>
  </div>

  <p id="search-count" class="text-xs text-zinc-400 dark:text-zinc-600 mb-6 font-mono"></p>
  <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
  <p id="no-results" class="hidden text-zinc-500 dark:text-zinc-400">{t('search.empty')}</p>
</BaseLayout>

<script define:vars={{ posts, totalStr, filteredStr }}>
  const input = document.getElementById('search-input');
  const grid = document.getElementById('results-grid');
  const count = document.getElementById('search-count');
  const noResults = document.getElementById('no-results');

  function renderCard(post) {
    const tags = post.tags.length
      ? `<div class="flex flex-wrap gap-1.5 mb-2">${post.tags.map(tag => `<a href="${post.base}/tags/${tag}" class="relative z-20 text-xs font-medium px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">${tag}</a>`).join('')}</div>`
      : '';
    const image = post.heroImage
      ? `<img src="${post.heroImage}" alt="${post.title.replace(/<[^>]+>/g,'')}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />`
      : `<div class="w-full h-full flex items-center justify-center"><span class="font-mono text-4xl text-zinc-300 dark:text-zinc-600">S</span></div>`;
    const desc = post.description ? `<p class="text-zinc-500 dark:text-zinc-400 text-sm line-clamp-2">${post.description}</p>` : '';
    return `
      <div class="group relative flex flex-col rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors bg-white dark:bg-zinc-900">
        <a href="${post.base}/blog/${post.slug}" class="absolute inset-0 z-10" aria-label="${post.title.replace(/<[^>]+>/g,'')}"></a>
        <div class="w-full h-44 overflow-hidden bg-zinc-100 dark:bg-zinc-800">${image}</div>
        <div class="relative p-4 flex flex-col flex-1">
          ${tags}
          <h2 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors leading-snug mb-1">${post.title}</h2>
          ${desc}
          <div class="flex items-center justify-between mt-auto pt-3">
            <p class="text-zinc-400 dark:text-zinc-600 text-xs font-mono">${post.date}</p>
            <span class="text-zinc-400 dark:text-zinc-600 text-xs">${post.readTime}</span>
          </div>
        </div>
      </div>`;
  }

  function render(filtered, isFiltered) {
    grid.innerHTML = filtered.map(renderCard).join('');
    count.textContent = isFiltered
      ? filteredStr.replace('{n}', filtered.length).replace('{total}', posts.length)
      : totalStr.replace('{n}', posts.length);
    noResults.classList.toggle('hidden', filtered.length > 0);
    grid.classList.toggle('hidden', filtered.length === 0);
  }

  render(posts, false);
  input.addEventListener('input', () => {
    const q = input.value.toLowerCase().trim();
    if (!q) { render(posts, false); return; }
    const filtered = posts.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.description.toLowerCase().includes(q) ||
      p.tags.some(tag => tag.toLowerCase().includes(q))
    );
    render(filtered, true);
  });
</script>
