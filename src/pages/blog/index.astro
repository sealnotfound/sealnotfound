---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl } from '@/i18n/index';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const posts = (await getCollection('blog'))
  .filter(p => p.slug.startsWith('en/') && !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const months = [...new Set(
  posts.map(p => p.data.pubDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }))
)];
---

<BaseLayout title={t('blog.title')}>
  <h1 class="text-2xl font-bold mb-6 text-zinc-900 dark:text-zinc-100">{t('blog.title')}</h1>

  <div class="flex flex-wrap gap-2 mb-8" id="filter-bar">
    <button data-month="all"
      class="filter-btn active text-xs font-medium px-3 py-1.5 rounded-full border transition-colors border-zinc-900 dark:border-zinc-100 bg-zinc-900 dark:bg-zinc-100 text-white dark:text-zinc-900">
      {t('blog.all')}
    </button>
    {months.map(month => (
      <button data-month={month}
        class="filter-btn text-xs font-medium px-3 py-1.5 rounded-full border transition-colors border-zinc-300 dark:border-zinc-700 text-zinc-600 dark:text-zinc-400 hover:border-zinc-500 dark:hover:border-zinc-400">
        {month}
      </button>
    ))}
  </div>

  {posts.length === 0 ? (
    <p class="text-zinc-500">{t('blog.empty')}</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5" id="cards-grid">
      {posts.map(post => (
        <BlogCard post={post} href={`/blog/${post.slug.replace('en/', '')}`} tagBase="/tags/" />
      ))}
    </div>
  )}
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-month]');
  const activeClass = ['border-zinc-900','dark:border-zinc-100','bg-zinc-900','dark:bg-zinc-100','text-white','dark:text-zinc-900'];
  const inactiveClass = ['border-zinc-300','dark:border-zinc-700','text-zinc-600','dark:text-zinc-400'];
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const month = btn.dataset.month!;
      buttons.forEach(b => { b.classList.remove(...activeClass); b.classList.add(...inactiveClass); });
      btn.classList.remove(...inactiveClass); btn.classList.add(...activeClass);
      cards.forEach(card => {
        if (card.closest('#filter-bar')) return;
        card.style.display = (month === 'all' || card.dataset.month === month) ? '' : 'none';
      });
    });
  });
</script>
