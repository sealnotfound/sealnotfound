---
import BlogPost from '@/layouts/BlogPost.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const all = await getCollection('blog');
  const posts = all
    .filter(p => p.slug.startsWith('en/') && !p.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return posts.map((post) => ({
    params: { slug: post.slug.replace('en/', '') },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();

const currentIndex = allPosts.findIndex(p => p.slug === post.slug);
const prevPost = allPosts[currentIndex + 1] ?? null;
const nextPost = allPosts[currentIndex - 1] ?? null;
---

<BlogPost
  title={post.data.title}
  description={post.data.description}
  pubDate={post.data.pubDate}
  tags={post.data.tags}
  heroImage={post.data.heroImage}
  prevPost={prevPost ? { slug: prevPost.slug.replace('en/', ''), title: prevPost.data.title } : null}
  nextPost={nextPost ? { slug: nextPost.slug.replace('en/', ''), title: nextPost.data.title } : null}
>
  <Content />
</BlogPost>
