---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BlogCard from '@/components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { useTranslations, getLangFromUrl } from '@/i18n/index';

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).filter(p => p.slug.startsWith('en/'));
  const tags = [...new Set(posts.flatMap(p => p.data.tags))];
  return tags.map(tag => ({ params: { tag }, props: { tag } }));
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { tag } = Astro.props;

const posts = (await getCollection('blog'))
  .filter(p => p.slug.startsWith('en/') && !p.data.draft && p.data.tags.includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`#${tag}`}>
  <div class="mb-8 flex items-center gap-3">
    <a href="/blog" class="text-zinc-400 dark:text-zinc-500 hover:text-zinc-600 dark:hover:text-zinc-300 text-sm transition-colors">{t('tag.back')}</a>
    <span class="text-zinc-300 dark:text-zinc-700">/</span>
    <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">{tag}</span>
    <span class="text-zinc-400 dark:text-zinc-500 text-sm">{posts.length}</span>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {posts.map(post => (
      <BlogCard post={post} href={`/blog/${post.slug.replace('en/', '')}`} tagBase="/tags/" />
    ))}
  </div>
</BaseLayout>
