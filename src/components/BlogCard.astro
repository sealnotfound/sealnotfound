---
import { readingTime } from '@/utils/readingTime';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  href: string;
  tagBase: string;
  class?: string;
}

const { post, href, tagBase, class: className } = Astro.props;
const plainTitle = post.data.title.replace(/<[^>]+>/g, '');
---

<div class:list={["group relative flex flex-col h-full rounded-xl overflow-hidden border border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 dark:hover:border-zinc-600 transition-colors bg-white dark:bg-zinc-900", className]}
  data-year={post.data.pubDate.getFullYear()}
  data-month={post.data.pubDate.getMonth() + 1}>
  <a href={href} class="absolute inset-0 z-10" aria-label={plainTitle}></a>

  <div class="w-full aspect-video overflow-hidden bg-zinc-100 dark:bg-zinc-800">
    {post.data.heroImage ? (
      <img src={post.data.heroImage} alt={plainTitle}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <span class="font-mono text-4xl text-zinc-300 dark:text-zinc-600">S</span>
      </div>
    )}
  </div>

  <div class="relative p-4 flex flex-col flex-1">
    {post.data.tags.length > 0 && (
      <div class="flex flex-wrap gap-1.5 mb-2">
        {post.data.tags.map((tag: string) => (
          <a href={`${tagBase}${tag}`}
            class="relative z-20 text-xs font-medium px-2 py-0.5 rounded-full bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400 hover:bg-amber-200 dark:hover:bg-amber-900/50 transition-colors">
            {tag}
          </a>
        ))}
      </div>
    )}
    <h2 class="font-semibold text-zinc-900 dark:text-zinc-100 group-hover:text-amber-600 dark:group-hover:text-amber-400 transition-colors leading-snug mb-1"
      set:html={post.data.title} />
    {post.data.description && (
      <p class="text-zinc-500 dark:text-zinc-400 text-sm line-clamp-2">{post.data.description}</p>
    )}
    <div class="flex items-center justify-between mt-auto pt-3">
      <p class="text-zinc-400 dark:text-zinc-600 text-xs font-mono">
        {post.data.pubDate.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
      </p>
      <span class="text-zinc-400 dark:text-zinc-600 text-xs">{readingTime(post.body)}</span>
    </div>
  </div>
</div>
